# Database Configuration
# For local development: postgresql://postgres:postgres@localhost:5432/timetable_db
# For Render: Use Render's DATABASE_URL environment variable or external database
TIMETABLE_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/timetable_db

# Supabase Configuration (optional, used instead of local PostgreSQL)
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Server Configuration
# Render automatically sets PORT environment variable
PORT=5000
